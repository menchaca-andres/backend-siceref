generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model roles {
  id_rol      Int        @id @default(autoincrement())
  codigo      String     @unique @db.VarChar(50)
  nom_rol     String     @db.VarChar(50)
  descrip_rol String     @db.Text
  rolPerms    rol_perm[]
  usuarios    usuarios[]
}

model permisos {
  id_per   Int        @id @default(autoincrement())
  codigo   String     @unique @db.VarChar(80)
  nombre   String     @db.VarChar(50)
  rolPerms rol_perm[]
}

model rol_perm {
  id_rol  Int
  id_per  Int
  rol     roles    @relation(fields: [id_rol], references: [id_rol])
  permiso permisos @relation(fields: [id_per], references: [id_per])

  @@id([id_rol, id_per])
}

model usuarios {
  id_usu     Int      @id @default(autoincrement())
  nom_usu    String   @db.VarChar(80)
  apell_usu  String   @db.VarChar(80)
  fecnac_usu DateTime @db.Date
  numcel_usu String   @db.VarChar(20)
  email_usu  String   @unique @db.VarChar(80)
  pass_usu   String   @db.Text

  id_rol  Int
  rol     roles     @relation(fields: [id_rol], references: [id_rol])
  id_ref  Int?
  refugio refugios? @relation(fields: [id_ref], references: [id_ref])
}

model refugios {
  id_ref     Int        @id @default(autoincrement())
  nom_ref    String     @db.VarChar(80)
  direc_ref  String     @db.VarChar(150)
  telef_ref  String     @db.VarChar(20)
  email_ref  String     @unique @db.VarChar(80)
  estado_ref Boolean    @default(true)
  usuarios   usuarios[]
}

model especies {
  id_esp  Int     @id @default(autoincrement())
  nom_esp String  @db.VarChar(50)
  razas   razas[]
}

model razas {
  id_raza  Int    @id @default(autoincrement())
  nom_raza String @db.VarChar(50)

  id_esp   Int
  especie  especies   @relation(fields: [id_esp], references: [id_esp])
  mascotas mascotas[]
}

model mascotas {
  id_ani Int @id @default(autoincrement())

  nom_mascot      String   @db.VarChar(80)
  fechanac_mascot DateTime @db.Date
  esteril_mascot  Boolean
  sexo_mascot     String   @db.VarChar(10)
  caract_mascot   String   @db.Text
  fechaing_mascot DateTime @default(now()) @db.Date

  id_raza Int
  raza    razas @relation(fields: [id_raza], references: [id_raza])
}
